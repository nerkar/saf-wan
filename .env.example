# Copy to `.env` for local development. Do not commit `.env`.

# PostgreSQL (Neon, Supabase, Vercel Postgres, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Auth.js — use the same value for both (generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET=
NEXTAUTH_SECRET=

# App URL (no trailing slash) — must match the URL you open in the browser
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# Google OAuth (optional — leave empty to hide “Continue with Google”)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Public site URL for QR codes and links (same host/port as NEXTAUTH_URL for local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Object storage (optional — add when uploads use Vercel Blob / S3)
# BLOB_READ_WRITE_TOKEN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET=
