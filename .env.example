# Copy to `.env` for local development. Do not commit `.env`.
# vercel-platform: mirror required vars in Vercel → Project → Settings → Environment Variables
# (see docs/vercel-platform-touchpoints.md)

# PostgreSQL (Neon, Supabase, Vercel Postgres, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Auth.js — use the same value for both (generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET=
NEXTAUTH_SECRET=
# Optional: set AUTH_DEBUG=true for verbose Auth.js logs (Google OAuth troubleshooting)

# App URL (no trailing slash) — must match the URL you open in the browser
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# Google OAuth (optional — leave empty to hide “Continue with Google”)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Public site URL for QR codes and links (same host/port as NEXTAUTH_URL for local dev).
# On Vercel: set to your deployment URL, e.g. https://your-app.vercel.app (no trailing slash).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Vercel / production (set in Vercel → Project → Settings → Environment Variables) ---
# DATABASE_URL — same as above; use pooled URL if your host recommends it (e.g. Neon).
# AUTH_SECRET — required; generate a strong random value (do not reuse local dev secrets in prod).
# NEXTAUTH_URL / AUTH_URL — production site URL (https://…), must match OAuth redirect URIs.
# NEXT_PUBLIC_APP_URL — same as NEXTAUTH_URL for this app (QR codes and public links).
# Google OAuth: add https://YOUR_DOMAIN/api/auth/callback/google to Authorized redirect URIs.

# Object storage — optional locally; required for direct file uploads on product edit (Vercel Blob)
# See docs/INTEGRATION_DEV2_PRODUCTS.md for size limits and upload route.
# BLOB_READ_WRITE_TOKEN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET=
