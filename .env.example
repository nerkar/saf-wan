# Copy to `.env` for local development. Do not commit `.env`.

# PostgreSQL (Neon, Supabase, Vercel Postgres, etc.)
DATABASE_URL=

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=
# Same as AUTH_SECRET if using NextAuth env naming in your version — align with Auth.js docs
NEXTAUTH_SECRET=

# App URL (no trailing slash for OAuth callbacks)
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# Google OAuth (Google Cloud Console)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Public site URL for QR codes and links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Object storage (Vercel Blob or S3-compatible) — add when storage is wired
# BLOB_READ_WRITE_TOKEN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET=
